# ---- Base stage: everything except torch ----
FROM python:3.11-slim AS base

RUN apt-get update && apt-get install -y --no-install-recommends \
    libgl1 \
    git \
    build-essential \
    openssh-client && \
    rm -rf /var/lib/apt/lists/*

# Everything EXCEPT torch, from normal PyPI
RUN pip install --no-cache-dir \
    eclipse-sumo \
    traci \
    gymnasium \
    flwr \
    numpy \
    pandas \
    matplotlib \
    seaborn \
    stable_baselines3 \
    tensorboard

WORKDIR /app

# ---- CPU target: use on Arch/Windows without GPU passthrough set up ----
FROM base AS cpu
# Torch disabled for fast debug builds — uncomment when ready
RUN pip3 install torch torchvision --index-url https://download.pytorch.org/whl/cpu
CMD ["sleep", "infinity"]

# ---- GPU target: use on your rig once NVIDIA Container Toolkit is set up ----
FROM base AS gpu
# Torch disabled for fast debug builds — uncomment when ready
RUN pip3 install torch torchvision --index-url https://download.pytorch.org/whl/cu132
CMD ["sleep", "infinity"]
